{
  "name": "aqaar-ai-concierge",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm --workspace frontend run dev",
    "build": "npm --workspace frontend run build",
    "lint": "npm --workspace frontend run lint",
    "typecheck": "npm --workspace frontend run typecheck",
    "test": "npm --workspace frontend run test",
    "backend:dev": "uvicorn backend.app.main:app --reload --host 127.0.0.1 --port 8000",
    "backend:test": "pytest backend/tests"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "postcss": ">=8.5.10",
    "esbuild": ">=0.28.1"
  }
}
